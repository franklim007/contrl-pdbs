        -- =============================================================================
-- check_standby.sql.j2
-- CDB: {{ cdb }} | HOST: {{ inventory_hostname }}
-- Entorno Oracle cargado desde: /home/oracle/{{ cdb }}.env
-- =============================================================================

SET LINESIZE   200
SET PAGESIZE     0
SET FEEDBACK   OFF
SET HEADING    OFF
SET TRIMOUT     ON
SET TRIMSPOOL   ON
SET NEWPAGE   NONE
SET VERIFY     OFF
SET ECHO       OFF

PROMPT ============================================================
PROMPT  ORACLE STANDBY STATUS REPORT
PROMPT  CDB      : {{ cdb }}
PROMPT  HOST     : {{ inventory_hostname }}
PROMPT ============================================================
SELECT 'FECHA    : ' || TO_CHAR(SYSDATE,'YYYY-MM-DD HH24:MI:SS') FROM dual;
PROMPT

-- BASE DE DATOS
PROMPT ------------------------------------------------------------
PROMPT  BASE DE DATOS
PROMPT ------------------------------------------------------------
SELECT
    'DB NAME       : ' || name            || CHR(10) ||
    'ROL           : ' || database_role   || CHR(10) ||
    'OPEN MODE     : ' || open_mode       || CHR(10) ||
    'PROTECTION    : ' || protection_mode
FROM v$database;
PROMPT

-- MRP
PROMPT ------------------------------------------------------------
PROMPT  MRP (Managed Recovery Process)
PROMPT ------------------------------------------------------------
SELECT
    'PROCESO       : ' || process         || CHR(10) ||
    'ESTADO        : ' || status          || CHR(10) ||
    'THREAD        : ' || thread#         || CHR(10) ||
    'SECUENCIA     : ' || sequence#       || CHR(10) ||
    'DELAY (min)   : ' || delay_mins
FROM v$managed_standby
WHERE process LIKE 'MRP%';

SELECT '*** ALERTA: MRP NO ENCONTRADO en v$managed_standby ***'
FROM dual
WHERE NOT EXISTS (
    SELECT 1 FROM v$managed_standby WHERE process LIKE 'MRP%'
);
PROMPT

-- LAG
PROMPT ------------------------------------------------------------
PROMPT  LAG (Data Guard Stats)
PROMPT ------------------------------------------------------------
SELECT
    RPAD(name, 20) || ': ' || NVL(value,'N/A') || ' ' || NVL(unit,'')
FROM v$dataguard_stats
WHERE name IN ('apply lag','transport lag','apply finish time')
ORDER BY name;
PROMPT

-- PDBs con problema (estado distinto de MOUNTED)
PROMPT ------------------------------------------------------------
PROMPT  PDBs CON PROBLEMA (estado distinto de MOUNTED)
PROMPT ------------------------------------------------------------
PROMPT  NOMBRE                         CON_ID  OPEN MODE          REST   STATUS
PROMPT  ------------------------------ ------  -----------------  -----  ----------

SELECT
    '  ' ||
    RPAD(p.name,       30) || '  ' ||
    RPAD(p.con_id,      6) || '  ' ||
    RPAD(p.open_mode,  17) || '  ' ||
    RPAD(p.restricted,  5) || '  ' ||
    NVL(d.status, 'N/A')
FROM v$pdbs p
LEFT JOIN dba_pdbs d ON d.con_id = p.con_id
WHERE p.name      != 'PDB$SEED'
  AND p.open_mode != 'MOUNTED'
ORDER BY p.name;

SELECT '  (Todas las PDBs en MOUNTED - OK)'
FROM dual
WHERE NOT EXISTS (
    SELECT 1 FROM v$pdbs
    WHERE name      != 'PDB$SEED'
      AND open_mode != 'MOUNTED'
);

PROMPT
SELECT
    '  Total PDBs        : ' || COUNT(*)                                                 || CHR(10) ||
    '  PDBs MOUNTED (OK) : ' || SUM(CASE WHEN open_mode  = 'MOUNTED' THEN 1 ELSE 0 END) || CHR(10) ||
    '  PDBs con problema : ' || SUM(CASE WHEN open_mode != 'MOUNTED' THEN 1 ELSE 0 END)
FROM v$pdbs
WHERE name != 'PDB$SEED';

PROMPT
PROMPT ============================================================
PROMPT  FIN DEL REPORTE
PROMPT ============================================================

EXIT;
